# ==============================================
# HACKATHON IoT 2026 - Variables d'environnement
# ==============================================
# IMPORTANT : Copier ce fichier en .env et remplir les valeurs réelles
# Ne jamais committer le fichier .env

# --- InfluxDB ---
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=CHANGEME_mot_de_passe_influxdb
INFLUXDB_ORG=hackathon-iot
INFLUXDB_BUCKET=sensors
INFLUXDB_TOKEN=CHANGEME_token_influxdb_secret

# --- Mosquitto MQTT ---
MOSQUITTO_USER=iotuser
MOSQUITTO_PASSWORD=CHANGEME_mot_de_passe_mqtt

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_mot_de_passe_grafana

# --- Node-RED ---
NODE_RED_CREDENTIAL_SECRET=CHANGEME_secret_nodered

# --- Notifications Telegram ---
# 1. Créer un bot via @BotFather sur Telegram → /newbot
# 2. Copier le token ci-dessous
# 3. Démarrer le bot, puis aller sur :
#    https://api.telegram.org/bot<TOKEN>/getUpdates  → noter le chat_id
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_ICI
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_ICI

# --- Notifications Email (Gmail) ---
# 1. Activer la vérification en 2 étapes sur votre compte Gmail
# 2. Aller sur : myaccount.google.com/apppasswords
# 3. Créer un mot de passe d'application "Node-RED IoT"
# 4. Remplir les champs ci-dessous
EMAIL_FROM=votre.email@gmail.com
EMAIL_TO=votre.email@gmail.com
EMAIL_PASS=votre-app-password-16-caracteres

# --- SMTP Grafana (mettre true si EMAIL configuré) ---
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com:587
